---
import LangToggle from "./LangToggle.astro";
---

<nav class="fixed top-0 left-0 right-0 z-50 glass border-b border-[var(--theme-border)]">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <!-- Brand -->
    <a href="#" class="flex items-center gap-2 text-[var(--theme-text)] hover:text-[var(--theme-primary)] transition-colors">
      <span class="text-lg">💧</span>
      <span class="font-display font-semibold text-sm tracking-wide">WENDYS</span>
    </a>

    <!-- Links -->
    <div class="flex items-center gap-1 sm:gap-3">
      <a href="#hero" class="hidden sm:block text-[11px] uppercase tracking-widest text-[var(--theme-text-muted)] hover:text-[var(--theme-primary)] transition-colors">Home</a>
      <a href="#who" class="hidden sm:block text-[11px] uppercase tracking-widest text-[var(--theme-text-muted)] hover:text-[var(--theme-primary)] transition-colors" data-i18n="nav.who">Story</a>
      <a href="#principles" class="hidden sm:block text-[11px] uppercase tracking-widest text-[var(--theme-text-muted)] hover:text-[var(--theme-primary)] transition-colors" data-i18n="nav.principles">Protocol</a>
      <a href="#family" class="hidden sm:block text-[11px] uppercase tracking-widest text-[var(--theme-text-muted)] hover:text-[var(--theme-primary)] transition-colors" data-i18n="nav.family">Network</a>
      <a
        href="https://github.com/AmDewSaroota/wendys-landing"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[11px] uppercase tracking-widest text-[var(--theme-text-muted)] hover:text-[var(--theme-primary)] transition-colors"
      >Source</a>
      <LangToggle />
    </div>
  </div>
</nav>
